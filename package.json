{
  "name": "smart-vs-mcp",
  "type": "module",
  "version": "1.0.0",
  "description": "Workspace-aware stdio wrapper for Visual Studio MCP HTTP endpoints",
  "author": "",
  "license": "MIT",
  "keywords": [
    "mcp",
    "visual-studio",
    "vs-mcp",
    "mcp-use",
    "workspace"
  ],
  "main": "dist/index.js",
  "bin": {
    "smart-vs-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx index.ts",
    "start": "node dist/index.js",
    "serve": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "deploy": "mcp-use deploy"
  },
  "dependencies": {
    "mcp-use": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "tailwindcss": "^4.2.0",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
