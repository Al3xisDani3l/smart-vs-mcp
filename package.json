{
  "name": "@al3xisdani3l/smart-vs-mcp",
  "type": "module",
  "version": "1.0.7",
  "description": "Workspace-aware stdio wrapper for Visual Studio MCP HTTP endpoints",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Al3xisDani3l/smart-vs-mcp.git"
  },
  "homepage": "https://github.com/Al3xisDani3l/smart-vs-mcp#readme",
  "bugs": {
    "url": "https://github.com/Al3xisDani3l/smart-vs-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "visual-studio",
    "vs-mcp",
    "mcp-use",
    "workspace"
  ],
  "main": "dist/index.js",
  "bin": {
    "smart-vs-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/mcp-use.json",
    "public/",
    "skills/",
    "hooks/",
    ".mcp.json",
    ".codex-plugin/",
    ".claude-plugin/",
    ".cursor-plugin/",
    "plugins/",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "gemini-extension.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx index.ts",
    "start": "node dist/index.js",
    "serve": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/SmartVsMcp.UnitTests",
    "test:integration": "vitest run tests/SmartVsMcp.IntegrationTests",
    "test:functional": "vitest run tests/SmartVsMcp.FunctionalTests",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:functional",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run build && npm test && npm pack --dry-run",
    "sync:version": "node scripts/sync-version.mjs",
    "changelog": "node scripts/update-changelog.mjs",
    "deploy": "mcp-use deploy"
  },
  "dependencies": {
    "mcp-use": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "tailwindcss": "^4.2.0",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
